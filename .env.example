# ============================================================
# A股Agent系统配置 — 复制本文件为 .env 并填入真实值
# ============================================================

# ---------- Tushare ----------
TUSHARE_TOKEN=your_tushare_token_here

# ---------- DeepSeek ----------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 高频低价值任务（新闻打分、字段抽取）
DEEPSEEK_FLASH_MODEL=deepseek-chat
# 低频高价值任务（综合报告、多空辩论）
DEEPSEEK_PRO_MODEL=deepseek-reasoner

# ---------- Claude（可选备用LLM）----------
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ---------- 默认LLM Provider ----------
# 可选值: deepseek | claude
LLM_PROVIDER=deepseek

# ---------- 推送渠道 ----------
# 可选值: serverchan | email | none
NOTIFY_CHANNEL=serverchan

# Server酱 SendKey（微信推送）
SERVERCHAN_SEND_KEY=your_serverchan_sendkey_here

# 邮箱推送（备选）
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# ---------- 数据缓存 ----------
# 缓存目录（相对项目根目录）
CACHE_DIR=data_cache
# 报告输出目录
REPORT_DIR=reports

# ---------- 选股参数默认值 ----------
# 最大候选股数量
MAX_CANDIDATES=10
# 市值下限（亿元）
MIN_MARKET_CAP=200
# 市值上限（亿元）
MAX_MARKET_CAP=5000
